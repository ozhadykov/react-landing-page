<nav class="sticky top-0 z-50 w-full border-b border-white/5 bg-base-100/70 backdrop-blur-xl">
  <div class="navbar max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="navbar-start lg:w-1/3">
      <!-- Hamburger for Drawer -->
      <label for="main-drawer" class="btn btn-ghost lg:hidden p-1 mr-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </label>
      
      <!-- Logo hidden on mobile start, moved to center or kept here for desktop? -->
      <!-- The user wants it centered, so I'll put it in navbar-center for all screens -->
    </div>
    
    <div class="navbar-center flex-1 justify-center">
      <a href="/" class="text-xl md:text-2xl font-bold tracking-tighter hover:text-primary transition-colors whitespace-nowrap">
        ASSEL <span class="text-primary">ZHADYKOVA</span>
      </a>
      
      <!-- Desktop menu hidden to keep logo centered, or moved to start/end -->
      <ul class="menu menu-horizontal px-1 gap-1 hidden lg:flex absolute left-0">
        <li><a href="/#about" class="hover:text-primary font-medium transition-all duration-300 text-sm">Обо мне</a></li>
        <li><a href="/#services" class="hover:text-primary font-medium transition-all duration-300 text-sm">Услуги</a></li>
      </ul>
      <ul class="menu menu-horizontal px-1 gap-1 hidden lg:flex absolute right-0">
        <li><a href="/#reviews" class="hover:text-primary font-medium transition-all duration-300 text-sm">Отзывы</a></li>
        <li><a href="/#community" class="hover:text-primary font-medium transition-all duration-300 text-sm">Сообщество</a></li>
      </ul>
    </div>
    
    <div class="navbar-end lg:w-1/3">
      <!-- Empty to balance -->
    </div>
  </div>
</nav>
