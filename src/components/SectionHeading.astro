---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
}

const { title, subtitle, centered = true } = Astro.props;
---

<div class={`mb-16 ${centered ? 'text-center' : 'text-left'}`}>
  <h2 class="text-3xl md:text-5xl font-black uppercase tracking-tighter mb-4 text-white">
    {title}
  </h2>
  {subtitle && (
    <p class="text-lg md:text-xl text-white/50 max-w-2xl mx-auto font-medium">
      {subtitle}
    </p>
  )}
  <div class={`mt-4 h-1 w-20 bg-primary ${centered ? 'mx-auto' : ''}`}></div>
</div>
