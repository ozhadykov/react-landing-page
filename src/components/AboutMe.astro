---
import { Image } from "astro:assets";
import SectionHeading from "./SectionHeading.astro";
import heroMain from "../assets/hero_main_2.JPG";

const achievements = [
  "Автор образовательных программ: «Ресурсная женщина», «Эффективная коммуникация с мужчинами», «Деньги по-женски»",
  "Создатель методологии трансформации «Квантовый скачок»",
  "Автор книги-методологии по отношениям",
  "Основатель женского сообщества «Assel women evolution 1»",
  "Автор проекта «Новая жизнь. 100 женщин с Ассель»"
];
---

<section id="about" class="py-24 bg-base-200/50 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading title="Ассель Жадыкова" subtitle="Наставник для женщин по изменению жизненных стратегий" />
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="relative group">
        <div class="absolute -inset-4 bg-primary/20 rounded-3xl blur-2xl group-hover:bg-primary/30 transition-all duration-500"></div>
        <div class="relative rounded-2xl overflow-hidden aspect-[3/4] border border-white/10 shadow-2xl">
          <Image 
            src={heroMain} 
            alt="Assel Zhadykova" 
            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700"
          />
        </div>
      </div>

      <div class="space-y-8">
        <div class="prose prose-invert max-w-none">
          <p class="text-xl md:text-2xl font-semibold leading-relaxed text-white/90 italic border-l-4 border-primary pl-6">
            «Я помогаю женщинам менять жизнь в 4-х сферах: здоровье, отношения, реализация и финансы»
          </p>
        </div>

        <div class="space-y-4">
          <h3 class="text-2xl font-bold uppercase tracking-widest text-primary mb-6">Достижения</h3>
          <ul class="space-y-4">
            {achievements.map((item) => (
              <li class="flex items-start gap-4 text-lg text-white/70 hover:text-white transition-colors">
                <span class="mt-1.5 h-2 w-2 rounded-full bg-primary shrink-0"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="pt-6">
          <a href="#services" class="btn-primary-custom">
            Перейти к программам
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
