---
import SectionHeading from "./SectionHeading.astro";
---

<section id="results" class="py-24 bg-base-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading title="До / После" subtitle="Реальные трансформации участниц программ" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Result Card 1 -->
      <div class="group relative aspect-video rounded-3xl overflow-hidden border border-white/5 shadow-2xl">
        <div class="absolute inset-0 flex transition-transform duration-500 ease-in-out group-hover:translate-x-[-100%]">
          <!-- Before -->
          <div class="min-w-full h-full bg-base-300 flex items-center justify-center relative">
            <span class="absolute top-6 left-6 px-4 py-2 bg-black/50 backdrop-blur-md rounded-full text-xs font-black uppercase tracking-widest border border-white/10">До</span>
            <div class="text-white/10 text-4xl font-black italic">BEFORE</div>
          </div>
          <!-- After -->
          <div class="min-w-full h-full bg-primary/20 flex items-center justify-center relative">
             <span class="absolute top-6 left-6 px-4 py-2 bg-primary/80 backdrop-blur-md rounded-full text-xs font-black uppercase tracking-widest">После</span>
             <div class="text-primary/20 text-4xl font-black italic uppercase">Квантовый Скачок</div>
          </div>
        </div>
        <!-- Hover indicator -->
        <div class="absolute bottom-6 right-6 bg-white/10 backdrop-blur-md px-4 py-2 rounded-full text-[10px] font-bold uppercase tracking-widest text-white/50 group-hover:opacity-0 transition-opacity">
          Наведите, чтобы увидеть результат
        </div>
      </div>

       <!-- Result Card 2 -->
       <div class="group relative aspect-video rounded-3xl overflow-hidden border border-white/5 shadow-2xl">
        <div class="absolute inset-0 flex transition-transform duration-500 ease-in-out group-hover:translate-x-[-100%]">
          <!-- Before -->
          <div class="min-w-full h-full bg-base-300 flex items-center justify-center relative">
            <span class="absolute top-6 left-6 px-4 py-2 bg-black/50 backdrop-blur-md rounded-full text-xs font-black uppercase tracking-widest border border-white/10">До</span>
            <div class="text-white/10 text-4xl font-black italic">BEFORE</div>
          </div>
          <!-- After -->
          <div class="min-w-full h-full bg-primary/20 flex items-center justify-center relative">
             <span class="absolute top-6 left-6 px-4 py-2 bg-primary/80 backdrop-blur-md rounded-full text-xs font-black uppercase tracking-widest">После</span>
             <div class="text-primary/20 text-4xl font-black italic uppercase">Новая Я</div>
          </div>
        </div>
         <!-- Hover indicator -->
         <div class="absolute bottom-6 right-6 bg-white/10 backdrop-blur-md px-4 py-2 rounded-full text-[10px] font-bold uppercase tracking-widest text-white/50 group-hover:opacity-0 transition-opacity">
          Наведите, чтобы увидеть результат
        </div>
      </div>
    </div>
  </div>
</section>
