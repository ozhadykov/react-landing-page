---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Квантовый скачок в отношениях">
  <main class="pt-24">
    <section class="py-20 bg-linear-to-b from-base-200 to-base-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div class="animate-fade-in-up">
            <span class="text-primary font-black uppercase tracking-[0.3em] text-sm mb-4 block">Практический курс</span>
            <h1 class="text-5xl md:text-7xl font-black uppercase tracking-tighter mb-8 leading-none">
              Квантовый скачок <br/> <span class="text-primary">в отношениях</span>
            </h1>
            <p class="text-xl text-white/70 mb-10 leading-relaxed font-medium">
              Это не лекции о женственности. И не разговоры «о любви». Это практический курс, который учит женщину реально взаимодействовать с мужчинами.
            </p>
            <div class="flex gap-4">
               <a href="#" class="btn-primary-custom">Записаться на курс</a>
            </div>
          </div>
          <div class="relative group animate-fade-in-up animate-delay-100">
             <div class="absolute -inset-4 bg-primary/20 rounded-3xl blur-2xl group-hover:bg-primary/30 transition-all duration-500"></div>
             <div class="relative aspect-square rounded-3xl bg-base-300 border border-white/10 flex items-center justify-center overflow-hidden">
                <div class="text-white/5 text-9xl font-black italic rotate-12">LOVE</div>
             </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          <div class="space-y-4 p-8 rounded-3xl bg-white/5 border border-white/5">
             <div class="text-primary text-3xl font-black">01</div>
             <h3 class="text-xl font-bold uppercase">Без манипуляций</h3>
             <p class="text-white/50">Учимся выстраивать честный и открытый диалог.</p>
          </div>
          <div class="space-y-4 p-8 rounded-3xl bg-white/5 border border-white/5">
             <div class="text-primary text-3xl font-black">02</div>
             <h3 class="text-xl font-bold uppercase">Без игр</h3>
             <p class="text-white/50">Отношения, основанные на взрослой позиции и уважении.</p>
          </div>
          <div class="space-y-4 p-8 rounded-3xl bg-white/5 border border-white/5">
             <div class="text-primary text-3xl font-black">03</div>
             <h3 class="text-xl font-bold uppercase">Психология</h3>
             <p class="text-white/50">Глубокое понимание того, как мыслят и действуют мужчины.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-base-200">
       <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
          <SectionHeading title="Для кого этот курс" centered={false} />
          <ul class="space-y-6">
            {[
              "Устали от повторяющихся сценариев в отношениях",
              "Хотите лучше понимать мужчин",
              "Хотите научиться выстраивать здоровые и зрелые отношения",
              "Готовы работать над собой и менять свою жизнь"
            ].map(item => (
              <li class="flex gap-4 items-center text-xl text-white/80 font-medium">
                 <span class="h-2 w-2 bg-primary rounded-full shrink-0"></span>
                 {item}
              </li>
            ))}
          </ul>
       </div>
    </section>

    <section class="py-24">
       <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <SectionHeading title="Результат" subtitle="Что вы получите после прохождения курса" />
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 text-left">
             {[
               "Понимание мужской психологии",
               "Новая стратегия коммуникации",
               "Уверенность в себе и своих границах",
               "Зрелые и гармоничные отношения"
             ].map(res => (
               <div class="p-8 rounded-3xl bg-base-300/50 border border-white/5 group hover:bg-primary transition-all">
                  <p class="font-bold uppercase tracking-tighter group-hover:text-white transition-colors">{res}</p>
               </div>
             ))}
          </div>
       </div>
    </section>

    <Footer />
  </main>
</Layout>
